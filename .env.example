# -----------------------------
# OpenRouter (LLM)
# -----------------------------
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: model slug (default: openai/gpt-4o)
# OPENROUTER_MODEL=openai/gpt-4o
# Optional: app attribution
# OPENROUTER_HTTP_REFERER=https://your-site.com
# OPENROUTER_APP_NAME=Steelman Snap

# -----------------------------
# Farcaster agent identity
# -----------------------------
# Custody EVM key — pays Neynar x402 + hub messages
CUSTODY_PRIVATE_KEY=0x...
# Ed25519 signer for casts (hex, no 0x)
SIGNER_PRIVATE_KEY=...
# The bot's Farcaster ID
AGENT_FID=0
# Username (without @) — used to detect mentions in incoming webhooks.
# Should match the fname you set via `npm run profile`.
AGENT_USERNAME=steelmanbot

# -----------------------------
# Profile (only used by `npm run profile`)
# -----------------------------
# AGENT_FNAME=steelmanbot
# AGENT_DISPLAY_NAME=Steelman Bot
# AGENT_BIO=Tag me on a contentious cast and I'll steelman it.
# AGENT_PFP_URL=https://example.com/pfp.png

# -----------------------------
# Upstash Redis (snap state)
# -----------------------------
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# -----------------------------
# One-time setup (only used by `npm run setup` / register / add-signer / swap)
# -----------------------------
# An EVM private key for a wallet you've pre-funded with ~$1 of ETH on Optimism
# and ~$0.50 of ETH on Base. The setup scripts will register an FID, add a
# signer, and swap a slice of the Base ETH to USDC for runtime x402 payments.
# After setup completes, copy the printed CUSTODY_PRIVATE_KEY / SIGNER_PRIVATE_KEY
# / AGENT_FID values into the section above. You don't need PRIVATE_KEY at runtime.
# PRIVATE_KEY=0x...

# -----------------------------
# Snap server
# -----------------------------
# Public base URL where this server is reachable. Vercel auto-sets VERCEL_URL,
# so you only need this for local dev or a custom domain.
# SNAP_PUBLIC_URL=https://steelman.example.com
